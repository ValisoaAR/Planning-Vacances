# Copier ce fichier en ".env" (même dossier que docker-compose.yml) et adapter les valeurs.

# Base de données Postgres
POSTGRES_USER=maroc
POSTGRES_PASSWORD=change_me
POSTGRES_DB=itineraire_maroc

# Secret utilisé pour signer les cookies de session (chaîne longue et aléatoire)
JWT_SECRET=change_me_to_a_long_random_string

# Hash bcrypt du PIN familial (voir README.md pour la commande de génération)
FAMILY_PIN_HASH=
